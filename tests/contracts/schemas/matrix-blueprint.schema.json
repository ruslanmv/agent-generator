{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruslanmv.com/matrix-definitions/schemas/matrix-blueprint.schema.json",
  "title": "Matrix Blueprint Contract",
  "description": "Locked source-of-truth contract that controls AI coders and prevents architecture drift.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "semver": {
      "type": [
        "string",
        "number"
      ],
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "isoDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "placeholder"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "enforcementValue": {
      "type": "string",
      "enum": [
        "off",
        "warn",
        "fail"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^(RMD|AGENT|ASVS|OWASP|SSDF|SLSA|SUPPLY|GHA|PY|FASTAPI|NEXT|FE|FRONTEND|DOCKER|OBS|MATRIXHUB|DOC|SEC|API)-[0-9]{3,4}$"
    },
    "sourceRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|\\.\\.)"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enforcementMatrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starter": {
          "$ref": "#/$defs/enforcementValue"
        },
        "standard": {
          "$ref": "#/$defs/enforcementValue"
        },
        "production": {
          "$ref": "#/$defs/enforcementValue"
        },
        "enterprise": {
          "$ref": "#/$defs/enforcementValue"
        }
      },
      "minProperties": 1
    }
  },
  "required": [
    "schema_version",
    "blueprint_id",
    "name",
    "project_type",
    "goal",
    "allowed_stack",
    "required_files",
    "forbidden"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "blueprint_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "project_type": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 10
    },
    "target_user": {
      "type": "string"
    },
    "quality_level": {
      "$ref": "#/$defs/qualityLevel"
    },
    "allowed_stack": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "required_pages": {
      "$ref": "#/$defs/stringArray"
    },
    "required_api_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^/"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "required_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathString"
      },
      "uniqueItems": true
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "allowed_change_scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "allowed_files"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/pathString"
            }
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
