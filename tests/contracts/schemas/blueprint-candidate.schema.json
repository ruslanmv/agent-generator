{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruslanmv.com/matrix-definitions/schemas/blueprint-candidate.schema.json",
  "title": "Blueprint Candidate",
  "description": "Candidate blueprint returned before the user selects the final controlled build path.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "semver": {
      "type": [
        "string",
        "number"
      ],
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "isoDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "placeholder"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "enforcementValue": {
      "type": "string",
      "enum": [
        "off",
        "warn",
        "fail"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^(RMD|AGENT|ASVS|OWASP|SSDF|SLSA|SUPPLY|GHA|PY|FASTAPI|NEXT|FE|FRONTEND|DOCKER|OBS|MATRIXHUB|DOC|SEC|API)-[0-9]{3,4}$"
    },
    "sourceRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|\\.\\.)"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enforcementMatrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starter": {
          "$ref": "#/$defs/enforcementValue"
        },
        "standard": {
          "$ref": "#/$defs/enforcementValue"
        },
        "production": {
          "$ref": "#/$defs/enforcementValue"
        },
        "enterprise": {
          "$ref": "#/$defs/enforcementValue"
        }
      },
      "minProperties": 1
    }
  },
  "required": [
    "schema_version",
    "candidate_id",
    "name",
    "summary",
    "template",
    "quality_level",
    "score",
    "why"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "template": {
      "type": "string"
    },
    "quality_level": {
      "$ref": "#/$defs/qualityLevel"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "why": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
