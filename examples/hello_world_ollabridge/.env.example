# OllaBridge Cloud — fill these by running pair_ollabridge.py with a fresh code.
# Copy this file to .env, run the pairing helper, and OLLABRIDGE_TOKEN is filled
# in for you.

OLLABRIDGE_BASE_URL=https://ruslanmv-ollabridge.hf.space
OLLABRIDGE_TOKEN=
OLLABRIDGE_DEVICE_ID=
OLLABRIDGE_MODEL=qwen2.5:1.5b

# Optional — used by hello_world.py to personalise the greeting.
USER_NAME=Ruslan
