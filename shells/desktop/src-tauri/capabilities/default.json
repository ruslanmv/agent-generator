{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main window. Grants access to the OS APIs the frontend's `platform/tauri.ts` adapter calls into. Anything not listed here is forbidden by Tauri's capability system.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "os:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    "opener:default",
    "opener:allow-open-url",
    "notification:default",
    "notification:allow-notify",
    "deep-link:default",
    "store:default",
    "stronghold:default",
    "core:event:default",
    "core:menu:default",
    "core:tray:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-fullscreen",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:webview:default"
  ]
}
