# Backend runtime configuration. Copy to `.env` for local development.
# All keys are namespaced AG_<NAME> and consumed by `app.settings.Settings`.

AG_ENV=dev
AG_LOG_LEVEL=INFO
AG_HOST=0.0.0.0
AG_PORT=8000

# SQLAlchemy URL. SQLite by default; postgres in prod:
#   AG_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agentgen
AG_DATABASE_URL=sqlite+aiosqlite:///./agent_generator.db

# Upstream services (optional in dev).
# AG_MATRIX_HUB_URL=https://matrix.example.com
# AG_OLLABRIDGE_URL=https://ruslanmv-ollabridge.hf.space

# Secrets backend. "memory" for dev, "vault" for prod (Batch 21).
AG_SECRETS_BACKEND=memory
# AG_VAULT_ADDR=https://vault.example.com:8200
# AG_VAULT_TOKEN=
# AG_VAULT_NAMESPACE=

# Auth (Batch 16). Generate a strong AG_JWT_SECRET in prod:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
AG_JWT_SECRET=change-me-or-the-app-will-yell-at-you
AG_PUBLIC_URL=http://localhost:5173

# GitHub OAuth app — create at https://github.com/settings/applications/new
# Authorization callback URL must equal:
#   ${AG_PUBLIC_URL}/api/auth/github/callback
# AG_GITHUB_CLIENT_ID=
# AG_GITHUB_CLIENT_SECRET=

# Bootstrap admin: first GitHub login with this email (or username when
# the user hides their email) is granted admin. The very first user to
# log in is always admin regardless.
# AG_ADMIN_EMAIL=you@example.com

# Telemetry (Batch 31).
# AG_OTLP_ENDPOINT=https://otel.example.com
# AG_SENTRY_DSN=
